# Arquivo legado com todas as variaveis num so lugar.
# Para desenvolvimento local, prefira:
# - apps/api/.env.local
# - apps/dashboard/.env.local
#
# Para deploy:
# - Vercel: usar as variaveis do dashboard
# - EasyPanel/API: usar as variaveis da API

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-publishable-key

# OpenAI (GPT-4o Vision + Whisper)
OPENAI_API_KEY=sk-...

# Anthropic (Claude — Agente Especialista)
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution.dominio.com
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE_NAME=elementus

# n8n
N8N_WEBHOOK_URL=https://seu-n8n.dominio.com/webhook

# App
API_PORT=3001
DASHBOARD_PORT=5173
VITE_API_URL=http://localhost:3001

# Microsoft 365 / Entra ID
VITE_MICROSOFT_CLIENT_ID=seu-app-client-id
VITE_MICROSOFT_TENANT_ID=seu-tenant-id-ou-common
VITE_MICROSOFT_REDIRECT_URI=http://localhost:5173/login
VITE_MICROSOFT_SCOPES=openid profile email offline_access User.Read Files.ReadWrite
VITE_MICROSOFT_ALLOWED_DOMAINS=elementus-sa.com.br
# Os cargos e assinaturas agora ficam no Supabase. Estas variaveis so entram
# se voce quiser um fallback local durante desenvolvimento.
VITE_MICROSOFT_DEFAULT_ROLE=technician
VITE_MICROSOFT_CEO_EMAILS=
VITE_MICROSOFT_MANAGER_EMAILS=
VITE_MICROSOFT_SUPERVISOR_EMAILS=
MICROSOFT_365_DRIVE_ID=drive-compartilhado-ou-onedrive-id
MICROSOFT_365_ROOT_FOLDER=Clientes/Elementus/Relatorios

NODE_ENV=development
